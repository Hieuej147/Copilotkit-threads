{
  "name": "@kiri_ikki/thread-runtime",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "start:title-worker": "node dist/title-worker-main.js",
    "reconcile": "node dist/reconcile-main.js",
    "agents": "node dist/agent-admin-cli.js",
    "db:migrate": "tsx src/migrate.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.57",
    "@copilotkit/runtime": "1.63.1",
    "@kiri_ikki/thread-contracts": "workspace:*",
    "cors": "2.8.5",
    "express": "5.2.1",
    "ioredis": "5.11.1",
    "jose": "6.2.3",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "uuid": "14.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.5",
    "@types/node": "22.19.1",
    "@types/pg": "8.15.6",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
