{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["global", "runtime", "agent", "auth", "examples"],
  "properties": {
    "global": {
      "type": "object",
      "required": ["projectId", "namespace"],
      "properties": {
        "projectId": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "agent": {
      "type": "object",
      "required": ["id", "url"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "url": { "type": "string" }
      }
    },
    "auth": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["development", "gateway", "jwt"] },
        "gatewayConfigured": { "type": "boolean" }
      }
    },
    "examples": {
      "type": "object",
      "required": ["enabled"],
      "properties": { "enabled": { "type": "boolean" } }
    }
  }
}
