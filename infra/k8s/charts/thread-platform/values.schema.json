{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["global", "runtime", "agent", "auth", "examples"],
  "properties": {
    "global": {
      "type": "object",
      "required": ["projectId", "namespace"],
      "properties": {
        "projectId": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "agent": {
      "type": "object",
      "required": ["id", "url"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "url": { "type": "string" },
        "allowedHosts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "defaultTimeoutMs": { "type": "integer", "minimum": 1000 },
        "defaultMaxConcurrentRuns": { "type": "integer", "minimum": 1 }
      }
    },
    "runtime": {
      "type": "object",
      "properties": {
        "registryCacheTtlMs": { "type": "integer", "minimum": 1000 },
        "poolMax": { "type": "integer", "minimum": 1 },
        "credentialSecret": { "type": "string" },
        "eventBatch": {
          "type": "object",
          "required": ["maxDelayMs", "maxSize", "maxBytes"],
          "properties": {
            "maxDelayMs": { "type": "integer", "minimum": 10 },
            "maxSize": { "type": "integer", "minimum": 1 },
            "maxBytes": { "type": "integer", "minimum": 1024 }
          }
        }
      }
    },
    "auth": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["development", "gateway", "jwt"] },
        "gatewayConfigured": { "type": "boolean" }
      }
    },
    "examples": {
      "type": "object",
      "required": ["enabled"],
      "properties": { "enabled": { "type": "boolean" } }
    },
    "reconciler": {
      "type": "object",
      "properties": {
        "deletedThreadRetentionDays": { "type": "integer", "minimum": 0 },
        "runEventRetentionDays": { "type": "integer", "minimum": 1 },
        "threadEventRetentionDays": { "type": "integer", "minimum": 1 },
        "titleJobRetentionDays": { "type": "integer", "minimum": 1 },
        "messageRetentionDays": { "type": "integer", "minimum": 1 },
        "runRetentionDays": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
