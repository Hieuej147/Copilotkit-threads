POSTGRES_URL=postgresql://agent:agent@localhost:5432/agent_threads
REDIS_URL=redis://localhost:6379
AGENT_NAMESPACE=starter
AGENT_ID=default

RUNTIME_PORT=4000
AGENT_URL=http://localhost:8000/agent
CORS_ORIGIN=http://localhost:3000
EVENT_RETENTION_DAYS=7
REDIS_STREAM_TTL_SECONDS=86400
THREAD_LOCK_TTL_SECONDS=120
TITLE_JOB_MAX_ATTEMPTS=3
TITLE_JOB_CLAIM_IDLE_MS=60000
RUN_STALE_AFTER_SECONDS=600
AUTH_MODE=development
AUTH_TENANT_HEADER=x-auth-tenant-id
AUTH_USER_HEADER=x-auth-user-id
AUTH_ROLES_HEADER=x-auth-roles
DEV_TENANT_ID=local
DEV_USER_ID=developer
RATE_LIMIT_REQUESTS_PER_MINUTE=120

# Required only when AUTH_MODE=jwt
JWT_ISSUER=
JWT_AUDIENCE=
JWT_JWKS_URL=
JWT_TENANT_CLAIM=tenant_id
JWT_USER_CLAIM=sub
JWT_ROLES_CLAIM=roles

OPENAI_API_KEY=
CHAT_MODEL=gpt-4.1-mini
TITLE_MODEL=gpt-4.1-mini
TITLE_BASE_URL=https://api.openai.com/v1
TITLE_API_KEY=
TITLE_TIMEOUT_MS=15000
AGENT_PORT=8000

WEB_PORT=3000
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_RUNTIME_URL=http://localhost:4000/api/copilotkit
NEXT_PUBLIC_THREAD_API_URL=http://localhost:4000
