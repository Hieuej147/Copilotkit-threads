{
  "name": "@kiri_ikki/thread-agent-check",
  "version": "0.1.1",
  "description": "AG-UI lifecycle and concurrency checker for LangGraph agents",
  "keywords": ["copilotkit", "langgraph", "ag-ui", "agent", "testing"],
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hieuej147/Copilotkit-threads.git",
    "directory": "packages/agent-check"
  },
  "homepage": "https://github.com/Hieuej147/Copilotkit-threads#readme",
  "bugs": {
    "url": "https://github.com/Hieuej147/Copilotkit-threads/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "bin": {
    "thread-agent-check": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.57"
  },
  "devDependencies": {
    "@types/node": "22.19.1",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20.19"
  }
}
